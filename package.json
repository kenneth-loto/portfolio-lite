{
  "name": "portfolio-lite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "content-collections build && bun --bun next build",
    "start": "bun --bun next start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:fix:unsafe": "biome check --write --unsafe",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "ui": "bunx --bun shadcn@latest add",
    "content-collections": "content-collections build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:load:og": "docker run --rm -i grafana/k6 run - < app/og/__tests__/og.load.js",
    "test:stress:og": "docker run --rm -i grafana/k6 run - < app/og/__tests__/og.stress.js",
    "test:load:rss": "docker run --rm -i grafana/k6 run - < app/rss/__tests__/rss.load.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@content-collections/core": "^0.14.3",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/next": "^0.2.11",
    "@teispace/next-themes": "^0.4.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "reading-time": "^1.5.0",
    "rehype-pretty-code": "^0.14.3",
    "shadcn": "^4.2.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/types": "^21.0.0",
    "@content-collections/cli": "^0.1.9",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.0",
    "vitest": "^4.1.6"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
